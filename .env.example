# ================================
# Database (PostgreSQL)
# ================================
# POSTGRES_DB: Ten database (khong dau, khong khoang trang)
POSTGRES_DB=finwallet
# POSTGRES_USER: User ket noi DB
POSTGRES_USER=finwallet
# POSTGRES_PASSWORD: Mat khau DB (thay bang secret that)
POSTGRES_PASSWORD=change-me
# DB_CONNECTION_STRING: Chuoi ket noi day du cho EF Core
DB_CONNECTION_STRING=Host=localhost;Port=5432;Database=finwallet;Username=finwallet;Password=change-me

# ================================
# Redis
# ================================
# REDIS_CONNECTION_STRING: Host:Port (co the kem password neu co)
REDIS_CONNECTION_STRING=localhost:6379

# ================================
# RabbitMQ
# ================================
# RABBITMQ_HOST: Hostname cua RabbitMQ
RABBITMQ_HOST=localhost
# RABBITMQ_USERNAME: Username (thay bang user that)
RABBITMQ_USERNAME=guest
# RABBITMQ_PASSWORD: Password (thay bang secret that)
RABBITMQ_PASSWORD=guest
# RABBITMQ_VHOST: Virtual host
RABBITMQ_VHOST=/

# ================================
# MinIO (S3 Compatible)
# ================================
# MINIO_ENDPOINT: Host:Port (khong kem protocol)
MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY: Access key (secret)
MINIO_ACCESS_KEY=change-me
# MINIO_SECRET_KEY: Secret key (secret)
MINIO_SECRET_KEY=change-me
# MINIO_BUCKET: Bucket luu receipt PDF
MINIO_BUCKET=finwallet-receipts
# MINIO_USE_SSL: true/false
MINIO_USE_SSL=false
# MINIO_PUBLIC_ENDPOINT: URL public de tra ve cho client
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# ================================
# JWT
# ================================
# JWT_ISSUER: Nha phat hanh token
JWT_ISSUER=FinWallet
# JWT_AUDIENCE: Doi tuong nhan token
JWT_AUDIENCE=FinWallet
# JWT_KEY: Bi mat ky token (toi thieu 32 ky tu)
JWT_KEY=change-this-to-very-long-secret-key
# JWT_EXPIRY_MINUTES: Thoi gian het han access token
JWT_EXPIRY_MINUTES=60

# ================================
# Refresh token
# ================================
# REFRESH_TOKEN_DAYS: So ngay het han refresh token
REFRESH_TOKEN_DAYS=7

# ================================
# Rate limiting
# ================================
# RATE_LIMIT_ENABLED: Bat/tat rate limit
RATE_LIMIT_ENABLED=true
# RATE_LIMIT_RPM: So request/phut
RATE_LIMIT_RPM=120

# ================================
# Seed du lieu (chi dung local/dev)
# ================================
# SEED_ENABLED: Bat/tat seed
SEED_ENABLED=true
# SEED_ADMIN_EMAIL: Email admin mac dinh
SEED_ADMIN_EMAIL=admin@finwallet.local
# SEED_ADMIN_PASSWORD: Mat khau admin mac dinh
SEED_ADMIN_PASSWORD=change-me
# SEED_WALLET: Tao vi mau
SEED_WALLET=true

# ================================
# Database migration
# ================================
# DB_APPLY_MIGRATIONS: Tu dong migrate khi start
DB_APPLY_MIGRATIONS=false

# ================================
# Seq logging
# ================================
# SEQ_SERVER_URL: URL Seq server
SEQ_SERVER_URL=http://localhost:5341

# ================================
# Webhook
# ================================
# WEBHOOK_ENABLED: Bat/tat webhook
WEBHOOK_ENABLED=false
# WEBHOOK_ENDPOINT: URL nhan webhook
WEBHOOK_ENDPOINT=
# WEBHOOK_SECRET: Bi mat HMAC
WEBHOOK_SECRET=

# ================================
# CORS
# ================================
# CORS_ALLOWED_ORIGINS: Danh sach origin duoc phep (phan tach bang dau phay)
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8082

# ================================
# Admin UI
# ================================
# ADMIN_HOST_PORT: Port public cho Admin UI (Docker)
ADMIN_HOST_PORT=8082

# ================================
# Environment
# ================================
# ASPNETCORE_ENVIRONMENT: Development/Production
ASPNETCORE_ENVIRONMENT=Development
